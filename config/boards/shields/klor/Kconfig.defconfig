if SHIELD_KLOR_LEFT
  config ZMK_KEYBOARD_NAME
    default "KLOR"
  config ZMK_SPLIT_ROLE_CENTRAL
    default y
  endif # LEFT

if SHIELD_KLOR_LEFT || SHIELD_KLOR_RIGHT
  config ZMK_SPLIT
    default y
  endif # LEFT RIGHT

config UART_0_INTERRUPT_DRIVEN
  depends on !ZMK_SPLIT_WIRED_UART_MODE_ASYNC
